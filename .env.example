VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Comma-separated allowed origins for Edge Functions CORS (prod domains).
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=""
# If set to "1", requests are blocked when ALLOWED_ORIGINS is empty.
REQUIRE_ALLOWED_ORIGINS="0"

# OCR (Edge Function `ocr-vietnamese`): gemini | openai
OCR_PROVIDER="gemini"
OCR_MODE="both"
OCR_MARKDOWN_STYLE="raw"

# Limits
# Max size (bytes) per image (decoded binary). Default keeps requests reasonable for edge runtimes.
OCR_MAX_IMAGE_BYTES="4000000"
# Max total size (bytes) per batch request (decoded binary).
OCR_BATCH_MAX_TOTAL_BYTES="20000000"

# Billing / abuse-control
# Credits charged per image. For batch, total charge = images.length * OCR_CREDITS_PER_IMAGE.
OCR_CREDITS_PER_IMAGE="1"

# Rate limit (server-side, per user + ip)
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_OCR_PER_WINDOW="20"
RATE_LIMIT_BILLING_PER_WINDOW="10"

# Idempotency / anti-replay (server-side)
IDEMPOTENCY_TTL_SECONDS="600"

# Gemini (Google AI)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MODEL_FALLBACK="gemini-2.5-flash"
GEMINI_TIMEOUT_MS="60000"

# OpenAI-compatible timeout (e.g. OpenRouter)
OPENAI_TIMEOUT_MS="60000"

# OpenAI-compatible (e.g. OpenRouter: OPENAI_BASE_URL + OPENAI_MODEL)
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_BASE_URL="https://api.openai.com/v1"
