VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# OCR (Edge Function `ocr-vietnamese`): gemini | openai
OCR_PROVIDER="gemini"
OCR_MODE="both"
OCR_MARKDOWN_STYLE="raw"

# Gemini (Google AI)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MODEL_FALLBACK="gemini-2.5-flash"
GEMINI_TIMEOUT_MS="60000"

# OpenAI-compatible (e.g. OpenRouter: OPENAI_BASE_URL + OPENAI_MODEL)
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_BASE_URL="https://api.openai.com/v1"
